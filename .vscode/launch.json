{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [

            ],
            "env": {
                "PYTHONUNBUFFERED": "1",
                "MASTER_ADDR": "localhost",
                "MASTER_PORT": "5624",
                "PYTHONNOUSERSITE": "1",
                "PATH": "${env:PATH}",
                "CUDA_HOME": "/usr/local/cuda-11.8",
                "LD_LIBRARY_PATH": "/usr/local/cuda-11.8/lib64",
                "PYTHONPATH": "${workspaceFolder}",
                "CUDA_LAUNCH_BLOCKING":"1"
            },
        },
    ]
}
